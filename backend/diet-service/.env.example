POSTGRES_HOST=<db-host>
POSTGRES_PORT=5432
POSTGRES_DB=test_db
POSTGRES_USER=여기에 입력
POSTGRES_PASSWORD=여기에 입력

FRONTEND_URL=http://localhost:3000

JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
# Must match login-service's JWT_EXPIRE_MINUTES (sliding-session refresh).
JWT_EXPIRE_MINUTES=180

# Product Service base URL (대체 상품 추천 RC-0105 등)
PRODUCT_SERVICE_URL=http://localhost:8016

# RC-0103 식단 사진 AI 분석 (Claude Vision). 비워두면 PREPARING으로 동작(기존과 동일).
ANTHROPIC_API_KEY=

# zero-db 이벤트 파이프라인(Kafka/MinIO/Vision worker) 연동용. 비어있으면
# 업로드/vision 콜백 엔드포인트는 501을 반환한다.
MINIO_ENDPOINT=http://10.10.20.10:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=diet-photos
VISION_CALLBACK_SECRET=
